{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omnisupport.local/contracts/release/index_manifest.schema.json",
  "title": "Week8 Index Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "index_release_id",
    "data_release_id",
    "chunk_strategy_version",
    "embedding_model",
    "embedding_dim",
    "provider",
    "built_at",
    "source_table",
    "total_chunks",
    "embedded_chunks",
    "skipped_chunks",
    "error_count",
    "quality_gate",
    "notes"
  ],
  "properties": {
    "index_release_id": { "type": "string", "minLength": 1 },
    "data_release_id": { "type": "string", "minLength": 1 },
    "chunk_strategy_version": { "type": "string", "minLength": 1 },
    "embedding_model": { "type": "string", "minLength": 1 },
    "embedding_dim": { "type": "integer", "minimum": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "built_at": { "type": "string", "format": "date-time" },
    "source_table": { "type": "string", "minLength": 1 },
    "total_chunks": { "type": "integer", "minimum": 0 },
    "embedded_chunks": { "type": "integer", "minimum": 0 },
    "skipped_chunks": { "type": "integer", "minimum": 0 },
    "error_count": { "type": "integer", "minimum": 0 },
    "quality_gate": { "type": "string", "enum": ["pass", "warn", "fail"] },
    "notes": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "elapsed_sec": { "type": ["number", "null"], "minimum": 0 }
  }
}
